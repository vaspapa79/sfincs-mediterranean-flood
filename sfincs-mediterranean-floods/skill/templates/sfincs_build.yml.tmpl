setup_config:
  tref: $tref
  tstart: $tstart
  tstop: $tstop
  dtout: 3600
  dthisout: 600
  outputformat: net
  alpha: 0.5
  manning_land: $manning_land
  manning_sea: $manning_sea
  rgh_lev_land: 0
  zsini: 0
  huthresh: 0.01
  advection: 1$pavbnd_line

setup_grid_from_region:
  region:
    bbox: [$west, $south, $east, $north]
  res: $res
  crs: $epsg
  rotated: false

setup_dep:
  datasets_dep:
    - elevtn: copdem30

setup_mask_active:
  zmin: $zmin
  zmax: $zmax
  fill_area: $fill_area
  drop_area: $drop_area

setup_mask_bounds:
  btype: waterlevel
  zmax: 0
  reset_bounds: true

setup_subgrid:
  datasets_dep:
    - elevtn: copdem30
  datasets_rgh:
    - lulc: esa_worldcover_2021
      reclass_table: $manning_lookup
  nr_subgrid_pixels: $subgrid_pixels
  nrmax: 4000
  write_dep_tif: false
  write_man_tif: false
$infiltration_block
setup_precip_forcing_from_grid:
  precip: $rain_dataset
  aggregate: false
$wind_block$pressure_block